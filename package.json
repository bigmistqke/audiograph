{
  "name": "audiograph",
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "app:dev": "pnpm --filter @audiograph/app dev",
    "app:build": "pnpm --filter @audiograph/app build",
    "typecheck": "pnpm -r typecheck",
    "autoformat:dev": "pnpm --filter @audiograph/autoformat dev",
    "autoformat:test": "pnpm --filter @audiograph/autoformat test",
    "autoformat:generate-tests": "pnpm --filter @audiograph/autoformat generate:tests"
  },
  "license": "MIT"
}
